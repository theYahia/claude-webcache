{
  "description": "claude-webcache SessionStart hook — print cache stats line",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hook-stats.cjs" }
        ]
      }
    ]
  }
}
